# ═══════════════════════════════════════════════════════════════════
#  Secrets — the real files stay local and are NEVER committed.
#  Each has a committed *.example twin: copy it to the real name and
#  fill in your own values.
#      cp packer/proxmox.pkrvars.hcl.example packer/proxmox.pkrvars.hcl
# ═══════════════════════════════════════════════════════════════════

# Packer variable files (Proxmox creds, builder passwords)
*.pkrvars.hcl

# Windows unattended install + Ubuntu cloud-init (embed passwords)
**/autounattend.xml
**/user-data

# Ansible inventory + connection vars
ansible/hosts
ansible/inventory.ini
ansible/vars/vars_deploy.yaml
ansible/vars/vars_node.yaml

# Kestra env + server config
kestra/.env
kestra/config/config.yaml

# ── Private keys / certs — never commit, no exceptions ──
*_id_rsa
*_id_rsa.pub
*_id_ed25519
*_id_ed25519.pub
*_id_ecdsa
id_rsa
id_dsa
*.pem
*.key
*.ppk
*.pfx

# ── Generic env files ──
.env
.env.*
!.env.example
